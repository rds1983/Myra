<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <DefineConstants>$(DefineConstants);MONOGAME</DefineConstants>
    <AssemblyName>Myra</AssemblyName>
    <PackageId>Myra</PackageId>
    <OutputPath>bin\MonoGame\$(Configuration)</OutputPath>
    <TargetFramework>netstandard2.0</TargetFramework>
  </PropertyGroup>
  
  <Choose>
    <!-- Define MATH_IFACES if net 7, 8, 9, or 10 -->
    <When Condition="'$(TargetFramework.TrimEnd(`0123456789.`))' == 'net' And ('$(TargetFramework)' == 'net7.0' Or '$(TargetFramework)' == 'net8.0' Or '$(TargetFramework)' == 'net9.0' Or '$(TargetFramework)' == 'net10.0')">
      <PropertyGroup>
        <DefineConstants>$(DefineConstants);MATH_IFACES</DefineConstants>
      </PropertyGroup>
    </When>

    <!-- Include Generic.Math lib if MATH_IFACES is NOT defined -->
    <When Condition="!$([System.Text.RegularExpressions.Regex]::IsMatch($(DefineConstants), '^(.*;)*MATH_IFACES(;.*)*$'))">
      <ItemGroup>
        <PackageReference Include="Generic.Math" Version="1.0.2" />
      </ItemGroup>
    </When>
  </Choose>

  <PropertyGroup Condition="'$(Configuration)'=='Release'">
    <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
  </PropertyGroup>

  <ItemGroup>
    <EmbeddedResource Include="Resources\**\*.*" />
  </ItemGroup>

  <ItemGroup>
    <Compile Remove="Platform\**\*.*" />
    <Compile Update="Graphics2D\UI\File\FileDialog.PlatformDependent.cs">
      <DependentUpon>FileDialog.cs</DependentUpon>
    </Compile>
    <Compile Update="Graphics2D\UI\File\FileDialog.Util.cs">
      <DependentUpon>FileDialog.cs</DependentUpon>
    </Compile>
    <Compile Update="Graphics2D\UI\Properties\PropertyGrid.SubGrid.cs">
      <DependentUpon>PropertyGrid.cs</DependentUpon>
    </Compile>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="FontStashSharp.Monogame" Version="1.5.2" />
    <PackageReference Include="AssetManagementBase" Version="0.7.1" />
    <PackageReference Include="XNAssets.MonoGame" Version="$(XNAssetsVersion)" />
    <PackageReference Include="XNAssets.FontStashSharp.MonoGame" Version="$(XNAssetsVersion)" />
    <PackageReference Include="info.lundin.math.dll" Version="$(InfoLundinMathVersion)" />
    <PackageReference Include="MonoGame.Framework.DesktopGL" PrivateAssets="All" Version="$(MonoGameVersion)" />
  </ItemGroup>
</Project>
