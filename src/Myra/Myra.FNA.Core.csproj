<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <DefineConstants>$(DefineConstants);FNA</DefineConstants>
    <TargetFramework>$(AppTargetFramework)</TargetFramework>
    <AssemblyName>Myra</AssemblyName>
    <PackageId>Myra.FNA.Core</PackageId>
    <OutputPath>bin\FNA.Core\$(Configuration)</OutputPath>
  </PropertyGroup>

  <Choose>
    <!-- Define MATH_IFACES if net 7, 8, 9, or 10 -->
    <When Condition="'$(TargetFramework.TrimEnd(`0123456789.`))' == 'net' And ('$(TargetFramework)' == 'net7.0' Or '$(TargetFramework)' == 'net8.0' Or '$(TargetFramework)' == 'net9.0' Or '$(TargetFramework)' == 'net10.0')">
      <PropertyGroup>
        <DefineConstants>$(DefineConstants);MATH_IFACES</DefineConstants>
      </PropertyGroup>
    </When>

    <!-- Include Generic.Math lib if MATH_IFACES is NOT defined -->
    <When Condition="!$([System.Text.RegularExpressions.Regex]::IsMatch($(DefineConstants), '^(.*;)*MATH_IFACES(;.*)*$'))">
      <ItemGroup>
        <PackageReference Include="Generic.Math" Version="1.0.2" />
      </ItemGroup>
    </When>
  </Choose>
  
  <ItemGroup>
    <EmbeddedResource Include="Resources\**\*.*" />
  </ItemGroup>

  <ItemGroup>
    <Compile Remove="Platform\**\*.*" />
  </ItemGroup>  

  <ItemGroup>
    <PackageReference Include="info.lundin.math.dll" Version="$(InfoLundinMathVersion)" />  
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\..\FontStashSharp\src\XNA\FontStashSharp.FNA.Core.csproj" />
    <ProjectReference Include="..\..\..\XNAssets\src\XNAssets.FontStashSharp\XNAssets.FontStashSharp.FNA.Core.csproj" />
    <ProjectReference Include="..\..\..\XNAssets\src\XNAssets\XNAssets.FNA.Core.csproj" />
  </ItemGroup>
</Project>
